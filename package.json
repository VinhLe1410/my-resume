{
	"name": "my-resume",
	"private": true,
	"scripts": {
		"dev": "pnpm --filter front-end dev & pnpm --filter back-end dev",
		"dev:frontend": "pnpm --filter front-end dev",
		"dev:backend": "pnpm --filter back-end dev",
		"build": "pnpm --filter front-end build",
		"build:backend": "pnpm --filter back-end build",
		"typecheck": "pnpm --filter front-end check",
		"lint": "biome lint .",
		"format": "biome format --write .",
		"check": "biome check --write .",
		"check:ci": "biome ci ."
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.9",
		"lefthook": "^2.1.4"
	}
}
